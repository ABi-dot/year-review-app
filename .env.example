DATABASE_URL="file:./dev.db"

# 豆瓣自动导入配置（可选）
# 配置后应用启动时会自动定时从豆瓣 RSS 导入新记录
# DOUBAN_USER_ID=你的豆瓣用户ID
# AUTO_IMPORT_INTERVAL=0 */6 * * *  # cron 表达式，默认每6小时

# AI 功能配置（支持 OpenAI 兼容格式和 Anthropic 原生格式）
# 不配置则 AI 年度总结和"猜你喜欢"功能不可用，热门推荐无需配置即可使用
#
# 示例：DeepSeek
# AI_API_ENDPOINT=https://api.deepseek.com/v1
# AI_API_KEY=sk-xxx
# AI_MODEL=deepseek-chat
#
# 示例：OpenRouter
# AI_API_ENDPOINT=https://openrouter.ai/api/v1
# AI_API_KEY=sk-or-v1-xxx
# AI_MODEL=anthropic/claude-sonnet-4
#
# 示例：Anthropic 原生
# AI_API_ENDPOINT=https://api.anthropic.com/v1
# AI_API_KEY=sk-ant-api03-xxx
# AI_MODEL=claude-sonnet-4-7-20251001
